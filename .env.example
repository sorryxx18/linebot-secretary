# ── 單位與 Bot 設定 ───────────────────────────────────────────────────────────
UNIT_NAME=第二救災救護大隊
UNIT_SHORT_NAME=二大隊
BOT_DISPLAY_NAME=二大隊行政小秘書

# ── LINE Messaging API ────────────────────────────────────────────────────────
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# ── Codex / OpenAI ─────────────────────────────────────────────────────────────
# 本版本採 Codex-first 回答模式。建議填 OPENAI_API_KEY；若主機已有 `codex login`，docker-compose 也會掛載 ~/.codex。
OPENAI_API_KEY=your_openai_api_key_here
CODEX_MODEL=gpt-5.4
CODEX_TIMEOUT=150

# ── Google Gemini API fallback ────────────────────────────────────────────────
# Codex 失敗時會 fallback 到 Gemini RAG 回答。
GOOGLE_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── Google Drive 同步 ─────────────────────────────────────────────────────────
# install.sh 會把 Service Account JSON 複製到 ./credentials/service-account.json
GOOGLE_SA_KEY=/app/credentials/service-account.json
DRIVE_FOLDER_ID=your_drive_folder_id_here
DRIVE_MANIFEST_PATH=/app/data/drive_manifest.json

# ── 服務設定 ──────────────────────────────────────────────────────────────────
PUBLIC_BASE_URL=https://your-public-domain.example.com
DRIVE_FOLDER_URL=https://drive.google.com/drive/folders/your_folder_id
DATA_DIR=/app/data

# ── 管理 API ──────────────────────────────────────────────────────────────────
# install.sh 會自動產生；請勿使用範例值。
ADMIN_TOKEN=change_this_to_a_strong_random_token
