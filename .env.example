# ── LINE Messaging API ────────────────────────────────────────────────────────
# 從 LINE Developers Console 取得
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# ── Google Gemini API ─────────────────────────────────────────────────────────
# 從 Google AI Studio (aistudio.google.com) 取得（免費）
GOOGLE_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── Google Drive 同步 ─────────────────────────────────────────────────────────
# Service Account JSON 金鑰路徑（絕對路徑）
GOOGLE_SA_KEY=C:\linebot-secretary\service_account.json
# Drive 資料夾 ID（從資料夾網址取得）
DRIVE_FOLDER_ID=your_drive_folder_id_here

# ── 服務設定 ──────────────────────────────────────────────────────────────────
# Cloudflare Tunnel 設定完成後填入公開網址
PUBLIC_BASE_URL=https://your-subdomain.trycloudflare.com
# 雲端資料庫連結（Flex 卡片按鈕）
DRIVE_FOLDER_URL=https://drive.google.com/drive/folders/your_folder_id

# ── Bot 設定 ──────────────────────────────────────────────────────────────────
BOT_DISPLAY_NAME=二大隊行政小秘書
# 管理 API 金鑰（自訂一個強密碼）
ADMIN_TOKEN=change_this_to_a_strong_random_token
